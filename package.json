{
  "name": "ipix",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "check:env": "node scripts/check-client-env.mjs",
    "groq:smoke": "node scripts/groq-smoke.mjs",
    "groq:smoke:test": "node --test scripts/lib/groq-allowlist-sync.test.mjs",
    "groq:baseline": "node scripts/capture-gemini-baseline.mjs",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test e2e/05-mobile-operator-matrix.spec.ts",
    "test:web015": "bash supabase/tests/web015/run.sh",
    "supabase:types": "supabase gen types typescript --linked --schema public,planner,graphql_public > app/src/types/supabase.ts",
    "supabase:migrations": "supabase migration list --linked",
    "supabase:push": "supabase db push --linked",
    "supabase:verify": "node scripts/verify-supabase.mjs",
    "supabase:verify-rls": "node scripts/verify-rls.mjs",
    "supabase:verify-booking-gate": "node scripts/verify-booking-gate.mjs",
    "supabase:verify-edge": "node scripts/verify-edge-functions.mjs",
    "supabase:verify-brand-intelligence": "node scripts/verify-brand-intelligence.mjs",
    "supabase:verify-edge-unit": "cd supabase/functions && deno test --frozen --allow-env _shared/bi-groq-guards.test.ts _shared/resolve-caller.test.ts _shared/llm/llm.test.ts _shared/llm/structured.test.ts brand-intelligence/handler.test.ts audit-asset-dna/handler.test.ts",
    "supabase:verify-edge-groq": "npm run supabase:verify-edge-unit",
    "seed:sample-brand": "node scripts/seed-sample-brand.mjs",
    "worktree:audit": "node scripts/worktree-audit.mjs",
    "worktree:add": "node scripts/worktree-add.mjs",
    "worktree:health": "node scripts/worktree-health.mjs",
    "worktree:health:all": "node scripts/worktree-health.mjs --all",
    "worktree:pre-delete": "node scripts/worktree-health.mjs --pre-delete",
    "worktree:health:test": "node --test scripts/lib/worktree-health-checks.test.mjs",
    "supabase:verify-planner": "node --experimental-strip-types scripts/verify-planner-scenario.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
