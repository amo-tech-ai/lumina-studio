# Worktree leak guard
.claude/worktrees/
.worktrees/
github/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.obsidian/
.opencode/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Graphify knowledge-graph artifacts (build/query outputs + AST cache, can reach 50MB+)
graphify-out/
**/graphify-out/
.firecrawl/

# app/ sub-project (Next.js + Mastra)
app/node_modules
app/.next
app/.mastra
app/.env
app/out
app/.env.sentry-build-plugin
.env.sentry-build-plugin

# Local backups
app/.backup-*/
.vercel
pr9-storefront-test/

# Claude Code local settings (may contain tokens)
.claude/settings.local.json
.claude/settings.local.json.backup
.claude/launch.json

# Claude Code local dirs — docs/agents stay local (may contain example keys)
.claude/docs/
.claude/agents/
# .claude/skills/ is versioned on GitHub — no real secrets in SKILL.md bodies
.claude/*.py

# Ignore local Cursor state by default
.cursor/*

# Version shared project configuration
!.cursor/rules/
!.cursor/rules/**/*.mdc
!.cursor/docs/
!.cursor/docs/**
!.cursor/mcp.example.json
.codex/

# Deprecated skills staging — canonical skills live in .claude/skills/
.agents/

# Design source files — not committed, copied into worktrees via .worktreeinclude
Universal design prompt/
Universal design prompt*.zip
