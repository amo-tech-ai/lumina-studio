{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "ipix-operator",
  "compatibility_date": "2026-07-08",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "ipix-operator"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  // IPI-586 · CF-AI-003 — Workers AI binding (no remote:true; that is local-dev only).
  // Official: https://developers.cloudflare.com/ai-gateway/integrations/aig-workers-ai-binding/
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  },
  // IPI-468: deployed Worker must fail closed; CopilotKit thread gating reads this flag at runtime.
  // CF-SEC-010: committed vars are static flags only. Environment-specific URLs/ids are injected
  // at deploy via GitHub environment variables → upload script `--var` (Wrangler is SSOT).
  "vars": {
    "MASTRA_STORAGE_MODE": "noop",
    "OPERATOR_AUTH_ENABLED": "true",
    // IPI-586: internal smoke route stays dark until explicitly flipped for a preview proof.
    "ENABLE_CF_AI_SMOKE": "false",
    // IPI-60: Cloudinary DAM env for detectEnv() — Workers lack VERCEL_ENV; fail-closed without this.
    "DAM_ENV": "staging"
  },
  // Wrangler-only aliases (do not affect Node next-dev / Vitest).
  // IPI-490 · CF-MIG-210: stub packages proven in dry-run Worker graph but unused
  // on the Worker default path (noop storage + client-only chat renderers).
  "alias": {
    "@ast-grep/napi": "./scripts/cf-ast-grep-stub.mjs",
    "@ast-grep/napi-darwin-arm64": "./scripts/cf-ast-grep-stub.mjs",
    "@ast-grep/napi-darwin-x64": "./scripts/cf-ast-grep-stub.mjs",
    "@ast-grep/napi-linux-arm64-gnu": "./scripts/cf-ast-grep-stub.mjs",
    "@ast-grep/napi-linux-arm64-musl": "./scripts/cf-ast-grep-stub.mjs",
    "@ast-grep/napi-linux-x64-gnu": "./scripts/cf-ast-grep-stub.mjs",
    "@ast-grep/napi-linux-x64-musl": "./scripts/cf-ast-grep-stub.mjs",
    "@ast-grep/napi-win32-arm64-msvc": "./scripts/cf-ast-grep-stub.mjs",
    "@ast-grep/napi-win32-ia32-msvc": "./scripts/cf-ast-grep-stub.mjs",
    "@ast-grep/napi-win32-x64-msvc": "./scripts/cf-ast-grep-stub.mjs",
    // Chat highlighting (streamdown → shiki): stub drops langs from Worker;
    // browser loads real Shiki via jsDelivr (see scripts/cf-shiki-stub.mjs).
    "shiki": "./scripts/cf-shiki-stub.mjs",
    "shiki/engine/javascript": "./scripts/cf-shiki-stub.mjs",
    "@shikijs/langs": "./scripts/cf-shiki-stub.mjs",
    "@shikijs/themes": "./scripts/cf-shiki-stub.mjs",
    "@shikijs/core": "./scripts/cf-shiki-stub.mjs",
    "@shikijs/engine-oniguruma": "./scripts/cf-shiki-stub.mjs",
    "@shikijs/vscode-textmate": "./scripts/cf-shiki-stub.mjs",
    // Default Worker storage is InMemoryStore (MASTRA_STORAGE_MODE=noop)
    "@mastra/pg": "./scripts/cf-mastra-pg-stub.mjs",
    "pg": "./scripts/cf-mastra-pg-stub.mjs",
    "pg-cloudflare": "./scripts/cf-mastra-pg-stub.mjs"
  },
  // IPI-472 · INFRA-001 — SSOT for preview vs production Worker names.
  // IPI-606 · CF-SEC-010 — secrets.required for cf-typegen + local dev validation.
  // vars, images, services, secrets must repeat per named env (Wrangler: not inherited).
  // No DATABASE_URL here until Hyperdrive (IPI-619). Runtime values via Infisical sync.
  "env": {
    "preview": {
      "name": "ipix-operator-preview",
      "vars": {
        "MASTRA_STORAGE_MODE": "noop",
        "OPERATOR_AUTH_ENABLED": "true",
        "ENABLE_CF_AI_SMOKE": "false",
        "DAM_ENV": "staging"
      },
      "ai": {
        "binding": "AI"
      },
      "images": {
        "binding": "IMAGES"
      },
      "services": [
        {
          "binding": "WORKER_SELF_REFERENCE",
          "service": "ipix-operator-preview"
        },
        {
          // IPI-510: same-zone Worker→Worker via *.workers.dev needs a service binding
          "binding": "AI_GATEWAY",
          "service": "ai-gateway"
        }
      ],
      "secrets": {
        // COPILOTKIT_LICENSE_TOKEN is optional — synced when present; SSE mode without it.
        // INTERNAL_WEBHOOK_SECRET optional — required only when ENABLE_CF_AI_SMOKE=true (IPI-586).
        "required": ["GEMINI_API_KEY", "SUPABASE_SERVICE_ROLE_KEY"]
      }
    },
    "production": {
      "name": "ipix-operator",
      "vars": {
        "MASTRA_STORAGE_MODE": "noop",
        "OPERATOR_AUTH_ENABLED": "true",
        "ENABLE_CF_AI_SMOKE": "false",
        "DAM_ENV": "prod"
      },
      "ai": {
        "binding": "AI"
      },
      "images": {
        "binding": "IMAGES"
      },
      "services": [
        {
          "binding": "WORKER_SELF_REFERENCE",
          "service": "ipix-operator"
        },
        {
          "binding": "AI_GATEWAY",
          "service": "ai-gateway"
        }
      ],
      "secrets": {
        // COPILOTKIT_LICENSE_TOKEN is optional — synced when present; SSE mode without it.
        "required": ["GEMINI_API_KEY", "SUPABASE_SERVICE_ROLE_KEY"]
      }
    }
  }
}
