# Lumina Operator — copy to .env.local (never commit real values)
# cp .env.example .env.local
#
# Required for agents (Gemini default):
#   GEMINI_API_KEY=
#   DATABASE_URL=
#   NEXT_PUBLIC_SUPABASE_URL=
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# Optional:
#   AI_PROVIDER=gemini          # openai only if you explicitly select OpenAI
#   GEMINI_MODEL=               # default gemini-3.1-flash-lite (see src/mastra/models.ts)
#   COPILOTKIT_LICENSE_TOKEN=   # when set, also requires INTELLIGENCE_* vars below
