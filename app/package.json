{
  "name": "ipix-operator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:infra && concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:agent": "mastra dev",
    "dev:ui": "next dev --turbopack -p 3002",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "typecheck": "tsc --noEmit",
    "build": "next build",
    "lint": "eslint .",
    "test": "vitest run",
    "start": "next start -p 3002",
    "dev:infra": "node scripts/copilotkit-dev-infra.mjs"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@ag-ui/mastra": "0.2.1-beta.2",
    "@ai-sdk/google": "^3.0.83",
    "@copilotkit/react-core": "1.61.0",
    "@copilotkit/runtime": "1.61.0",
    "@libsql/client": "^0.15.15",
    "@mastra/client-js": "1.23.2",
    "@mastra/core": "1.41.0",
    "@mastra/libsql": "1.1.0-alpha.2",
    "@mastra/memory": "1.0.1-alpha.1",
    "@mastra/pg": "1.12.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4",
    "libsql": "^0.5.22",
    "lucide-react": "^0.525.0",
    "mastra": "1.1.0-alpha.3",
    "next": "16.1.2",
    "next-cloudinary": "^6.17.5",
    "next-themes": "^0.4.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@ag-ui/client": "0.0.57",
    "@ag-ui/core": "0.0.57",
    "@ag-ui/encoder": "0.0.57",
    "@ag-ui/proto": "0.0.57"
  }
}
