{
  "name": "ipix-operator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "NEXT_PRIVATE_WORKER_THREADS=false next build",
    "prebuild": "node scripts/sync-groq-models.mjs",
    "dev": "npm run dev:infra && concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:agent": "mastra dev",
    "dev:ui": "next dev --turbopack -p 3002",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "typecheck": "tsc --noEmit && npm run cf-typegen && tsc --noEmit -p tsconfig.cf-bindings.json",
    "lint": "eslint .",
    "test": "vitest run",
    "start": "next start -p 3002",
    "dev:infra": "node scripts/copilotkit-dev-infra.mjs",
    "preview": "node scripts/sync-groq-models.mjs && rm -rf .next .open-next && npm run build:cf && opennextjs-cloudflare preview",
    "deploy": "node scripts/sync-groq-models.mjs && rm -rf .next .open-next && npm run build:cf && opennextjs-cloudflare deploy",
    "upload": "node scripts/sync-groq-models.mjs && rm -rf .next .open-next && npm run build:cf && opennextjs-cloudflare upload",
    "build:cf": "opennextjs-cloudflare build && npm run check:worker-bundle",
    "cf-typegen": "wrangler types cloudflare-env.d.ts --env-interface CloudflareEnv --include-runtime=false",
    "check:cf-types": "wrangler types cloudflare-env.d.ts --env-interface CloudflareEnv --include-runtime=false --check",
    "check:worker-bundle": "node scripts/check-worker-bundle-size.mjs",
    "verify:cloudinary-pipeline": "node scripts/verify-cloudinary-pipeline.mjs",
    "verify:cloudinary-webhook-live": "node scripts/verify-cloudinary-webhook-live.mjs",
    "verify:cloudflare-gateway": "node scripts/verify-cloudflare-gateway.mjs"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@ag-ui/mastra": "0.2.1-beta.2",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/openai-compatible": "^1.0.42",
    "@copilotkit/react-core": "1.61.0",
    "@copilotkit/runtime": "1.61.0",
    "@libsql/client": "^0.15.15",
    "@mastra/client-js": "1.23.2",
    "@mastra/core": "1.41.0",
    "@mastra/libsql": "1.1.0-alpha.2",
    "@mastra/memory": "1.0.1-alpha.1",
    "@mastra/pg": "1.12.0",
    "@opennextjs/cloudflare": "1.20.2",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@sentry/nextjs": "^10.65.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "hono": "^4",
    "libsql": "^0.5.22",
    "lucide-react": "^0.525.0",
    "mastra": "1.1.0-alpha.3",
    "next": "16.2.11",
    "next-cloudinary": "^6.17.5",
    "next-themes": "^0.4.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "workers-ai-provider": "^3.3.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.2.4",
    "wrangler": "^4.107.1"
  },
  "overrides": {
    "@ag-ui/client": "0.0.57",
    "@ag-ui/core": "0.0.57",
    "@ag-ui/encoder": "0.0.57",
    "@ag-ui/proto": "0.0.57",
    "shell-quote": "1.9.0",
    "next": {
      "postcss": "8.5.10"
    },
    "sharp": "0.35.3",
    "@ag-ui/mastra": {
      "@ai-sdk/provider-utils": "4.0.30"
    }
  }
}
