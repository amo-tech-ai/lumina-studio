# Required — Mastra Postgres storage for agent/checkpoint persistence
# Use Supabase pooler connection string (transaction mode, port 6543)
DATABASE_URL=

# Required — agents will not work without this (Mastra + @ai-sdk/google)
GEMINI_API_KEY=

# AI provider for dev startup checks (runtime uses Mastra/Gemini until GROQ-002+). Default: gemini
# Valid: gemini | groq | openai
AI_PROVIDER=gemini

# Groq — server-only (Infisical / Vercel / Supabase Edge secrets). Never NEXT_PUBLIC_*.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Llama 3.x decommission on Groq 2026-08-16 — use gpt-oss replacements (see config/groq-models.json)
GROQ_MODEL_DEFAULT=openai/gpt-oss-120b
GROQ_MODEL_FAST=openai/gpt-oss-20b
GROQ_MODEL_STRUCTURED=openai/gpt-oss-20b
GROQ_MODEL_STRUCTURED_HEAVY=openai/gpt-oss-120b
GROQ_MODEL_VISION=
GROQ_MODEL_VISION_EXPERIMENTAL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_COMPOUND=groq/compound
GROQ_MODEL_COMPOUND_MINI=groq/compound-mini
GROQ_MODEL_STT=whisper-large-v3-turbo
GROQ_MODEL_SAFETY=openai/gpt-oss-safeguard-20b

# Per-function Gemini fallbacks during Groq rollout (GROQ-003+)
BI_USE_GEMINI=0
DNA_USE_GEMINI=1

# Optional: override Gemini model (registry default: gemini-3.1-flash-lite; see src/mastra/models.ts)
GEMINI_MODEL=

# Supabase — for agent write tools that call edge functions (IPI2-84 / no silent writes)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
# Public anon key for the browser login client (@supabase/ssr). Safe to expose (RLS-protected).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudinary — public keys for Upload Widget + next/image (never the API secret)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
# Server-only fallback mapped to NEXT_PUBLIC at build (see next.config.ts env)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=

# Optional (CopilotKit Intelligence — only required when COPILOTKIT_LICENSE_TOKEN is set)
COPILOTKIT_LICENSE_TOKEN=
INTELLIGENCE_API_KEY=
INTELLIGENCE_API_URL=http://localhost:4201
INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4401

# Optional (runtime config)
LOG_LEVEL=info

# Sentry (amo-2b / javascript-nextjs) — DSN is public; auth token is build-only secret
# https://amo-2b.sentry.io/projects/javascript-nextjs/
NEXT_PUBLIC_SENTRY_DSN=https://e81a2fa47d9313d1f43efde9499657f4@o4511711904137216.ingest.us.sentry.io/4511711906168832
SENTRY_DSN=https://e81a2fa47d9313d1f43efde9499657f4@o4511711904137216.ingest.us.sentry.io/4511711906168832
# Source maps upload (CI / local build) — never commit the token
# SENTRY_AUTH_TOKEN=
# Or use gitignored .env.sentry-build-plugin in app/

# Developer: show internal CopilotKit/Mastra tool-call cards in chat (default: hidden)
# NEXT_PUBLIC_COPILOT_DEBUG_TOOLS=true

# IPI2-127 — operator auth gate. When "true", /app/* requires a Supabase session
# (middleware redirects to /login otherwise). Keep "false" until login is wired
# to Supabase, or all operators get locked out.
OPERATOR_AUTH_ENABLED=false
