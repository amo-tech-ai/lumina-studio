# Required — Mastra Postgres storage for agent/checkpoint persistence
# Use Supabase pooler connection string (transaction mode, port 6543)
DATABASE_URL=

# Required — agents will not work without this (Mastra + @ai-sdk/google)
GEMINI_API_KEY=

# AI provider for dev startup checks (runtime uses Mastra/Gemini). Default: gemini
# Set AI_PROVIDER=openai only if you explicitly wire OpenAI elsewhere.
AI_PROVIDER=gemini

# Optional: override Gemini model (registry default: gemini-3.1-flash-lite; see src/mastra/models.ts)
GEMINI_MODEL=

# Supabase — for agent write tools that call edge functions (IPI2-84 / no silent writes)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
# Public anon key for the browser login client (@supabase/ssr). Safe to expose (RLS-protected).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional (CopilotKit Intelligence — only required when COPILOTKIT_LICENSE_TOKEN is set)
COPILOTKIT_LICENSE_TOKEN=
INTELLIGENCE_API_KEY=
INTELLIGENCE_API_URL=http://localhost:4201
INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4401

# Optional (runtime config)
LOG_LEVEL=info

# Developer: show internal CopilotKit/Mastra tool-call cards in chat (default: hidden)
# NEXT_PUBLIC_COPILOT_DEBUG_TOOLS=true

# IPI2-127 — operator auth gate. When "true", /app/* requires a Supabase session
# (middleware redirects to /login otherwise). Keep "false" until login is wired
# to Supabase, or all operators get locked out.
OPERATOR_AUTH_ENABLED=false
