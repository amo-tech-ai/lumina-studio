# Required — agents will not work without this
GEMINI_API_KEY=

# Optional: override Gemini model (registry default: gemini-2.5-flash; see src/mastra/models.ts)
GEMINI_MODEL=

# Supabase — for agent write tools that call edge functions (IPI2-84 / no silent writes)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional (CopilotKit Intelligence — enables threads/persistence/analytics)
COPILOTKIT_LICENSE_TOKEN=
INTELLIGENCE_API_KEY=
INTELLIGENCE_API_URL=http://localhost:4201
INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4401

# Optional (runtime config)
LOG_LEVEL=info
