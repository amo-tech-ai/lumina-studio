# Required — agents will not work without this
GEMINI_API_KEY=

# Optional: override Gemini model (registry default: gemini-3.5-flash; see src/mastra/models.ts)
GEMINI_MODEL=

# Supabase — for agent write tools that call edge functions (IPI2-84 / no silent writes)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
# Public anon key for the browser login client (@supabase/ssr). Safe to expose (RLS-protected).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional (CopilotKit Intelligence — enables threads/persistence/analytics)
COPILOTKIT_LICENSE_TOKEN=
INTELLIGENCE_API_KEY=
INTELLIGENCE_API_URL=http://localhost:4201
INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4401

# Optional (runtime config)
LOG_LEVEL=info

# IPI2-127 — operator auth gate. When "true", /app/* requires a Supabase session
# (middleware redirects to /login otherwise). Keep "false" until login is wired
# to Supabase, or all operators get locked out.
OPERATOR_AUTH_ENABLED=false
