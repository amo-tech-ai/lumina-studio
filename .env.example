# iPix — copy to .env.local (never commit real values)
# Shared public client keys + repo-root / Supabase Edge secrets.
# App-only runtime config lives in app/.env.example.
# Recommended: infisical run -- npm run dev

# ─── Public client config (non-sensitive — RLS / publishable keys only) ───────
# Keys ordered alphabetically to satisfy dotenv-linter.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# ─── Server / Edge secrets — set in Supabase/Infisical, never NEXT_PUBLIC_ ────
# GEMINI_API_KEY=           # Supabase Edge secrets only
# FIRECRAWL_API_KEY=        # start-brand-crawl / firecrawl-webhook
# FIRECRAWL_WEBHOOK_SECRET= # HMAC verify on firecrawl-webhook
# SUPABASE_SERVICE_ROLE_KEY=
