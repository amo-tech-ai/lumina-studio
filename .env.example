# iPix — copy to .env.local (never commit real values)
# Recommended: infisical run -- npm run dev

# ─── Vite client (public — RLS / publishable keys only) ───────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Optional client IDs (OAuth UI only — no secrets)
VITE_GOOGLE_CLIENT_ID=
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ─── Server / Edge only (never VITE_ prefix) ────────────────────────────────
# GEMINI_API_KEY=           # Supabase Edge secrets only
# SUPABASE_SERVICE_ROLE_KEY=
